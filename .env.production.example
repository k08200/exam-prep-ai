# Copy this file to your production secret store and replace every placeholder.

ENVIRONMENT=production
POSTGRES_DB=examprep_db
POSTGRES_USER=examprep
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql+asyncpg://examprep:replace-with-a-long-random-password@db:5432/examprep_db

SECRET_KEY=replace-with-at-least-32-random-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

USE_MOCK_CLAUDE=false
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
CLAUDE_MODEL=claude-opus-4-1-20250805
THINKING_BUDGET_ANALYSIS=30000
THINKING_BUDGET_GENERATION=10000

UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=52428800
MAX_UPLOAD_FILES=10
MATERIAL_PROCESSING_STALE_MINUTES=30

RUN_MIGRATIONS=true
AUTO_CREATE_TABLES=false
CORS_ORIGINS=https://your-frontend.example.com

NEXT_PUBLIC_API_URL=https://your-api.example.com
