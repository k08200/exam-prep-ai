# Backend
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://examprep:examprep_password@db:5432/examprep_db
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI — set USE_MOCK_CLAUDE=true to run fully without an API key (demo/dev mode).
# For real AI, set USE_MOCK_CLAUDE=false and choose AI_PROVIDER below.
USE_MOCK_CLAUDE=true
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
# OpenRouter option: set AI_PROVIDER=openrouter and add your key below.
# The default OpenRouter model is Claude Opus 4.8; replace it with any OpenRouter model slug if desired.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.8
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Exam Prep AI
THINKING_BUDGET_ANALYSIS=30000
THINKING_BUDGET_GENERATION=10000
CLAUDE_THINKING_EFFORT=high

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
MAX_USER_STORAGE_BYTES=2147483648
MAX_ANALYSIS_INPUT_CHARS=600000
MAX_UPLOAD_FILES=10
MATERIAL_PROCESSING_STALE_MINUTES=30
ANALYSIS_RUN_STALE_MINUTES=30
EXAM_GENERATION_STALE_MINUTES=30
REQUEST_TIMEOUT_SECONDS=60
AUTH_RATE_LIMIT_MAX_FAILURES=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AI_STREAM_HEARTBEAT_SECONDS=15
AI_STREAM_EVENT_TIMEOUT_SECONDS=180
# Per-account daily AI safeguards (UTC day): analysis runs, generated questions, graded answers
MAX_DAILY_AI_ANALYSES=10
MAX_DAILY_AI_GENERATED_QUESTIONS=200
MAX_DAILY_AI_GRADES=300
RUN_MIGRATIONS=true
AUTO_CREATE_TABLES=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3003,http://127.0.0.1:3003

# Frontend
BACKEND_PORT=8001
FRONTEND_PORT=3003
POSTGRES_PORT=5434
NEXT_PUBLIC_API_URL=http://localhost:8001

# Database
POSTGRES_DB=examprep_db
POSTGRES_USER=examprep
POSTGRES_PASSWORD=examprep_password
