# Backend
DATABASE_URL=postgresql+asyncpg://examprep:examprep_password@db:5432/examprep_db
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI — set USE_MOCK_CLAUDE=true to run fully without an API key (demo/dev mode)
USE_MOCK_CLAUDE=true
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7
THINKING_BUDGET_ANALYSIS=30000
THINKING_BUDGET_GENERATION=10000

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database
POSTGRES_DB=examprep_db
POSTGRES_USER=examprep
POSTGRES_PASSWORD=examprep_password
